{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "api/oauth_linkedin.py", "use": "@vercel/python" },
    { "src": "api/oauth_x.py", "use": "@vercel/python" },
    { "src": "api/cron.py", "use": "@vercel/python" },
    { "src": "landing/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/oauth/linkedin/callback", "dest": "/api/oauth_linkedin.py" },
    { "src": "/api/oauth/x/callback", "dest": "/api/oauth_x.py" },
    { "src": "/api/cron", "dest": "/api/cron.py" },
    { "src": "/", "dest": "/landing/index.html" }
  ],
  "crons": [
    { "path": "/api/cron", "schedule": "0 * * * *" }
  ]
}
